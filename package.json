{
  "name": "senate",
  "version": "0.2.0",
  "description": "Multi-model orchestration CLI — consult claude, vibe, gemini in parallel and synthesize their answers",
  "type": "module",
  "bin": {
    "senate": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "tsx src/cli.ts",
    "dev": "tsx watch src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node --test dist/__tests__/*.test.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "ai",
    "claude",
    "vibe",
    "mistral",
    "gemini",
    "codex",
    "orchestration",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "log-update": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
